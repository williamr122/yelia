# YELIA4AP - ejemplo para Docker/Desarrollo
ENV=development
FLASK_ENV=development
FLASK_SECRET_KEY=cambia-esta-clave
AUTO_OPEN_BROWSER=0
FRONTEND_URL=http://localhost:3000
NEXT_FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_TTS_PROVIDER=browser
TTS_MAX_TEXT_LEN=1200

# PostgreSQL 15 (Docker Compose)
POSTGRES_DB=yelia4ap
POSTGRES_USER=yelia
POSTGRES_PASSWORD=cambia-esta-clave-postgres
DATABASE_URL=postgresql://yelia:cambia-esta-clave-postgres@db:5432/yelia4ap

# Setup inicial de administrador
SETUP_TOKEN=cambia-este-token-de-setup
ADMIN_USERNAME=admin
ADMIN_PASSWORD=cambia-esta-contrasena-admin
ADMIN_EMAIL=admin@yelia.local

# APIs opcionales de IA
GROQ_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
